# --- Database (MongoDB Atlas free M0 cluster) ---
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/pulsecrm?retryWrites=true&w=majority

# --- Auth ---
# Any long random string (e.g. `openssl rand -hex 32`)
JWT_SECRET=change-me-to-a-long-random-string

# --- Automation service token (used by n8n / cron callers) ---
SERVICE_TOKEN=change-me-to-another-long-random-string

# --- Email (Resend free tier: 100 emails/day). Leave blank to log emails to console instead. ---
RESEND_API_KEY=
EMAIL_FROM=Pulse CRM <onboarding@resend.dev>

# --- URLs ---
# Local dev: http://localhost:5174
# Production (Vercel): https://your-app.vercel.app
CLIENT_URL=http://localhost:5174
PORT=4000

# --- Fallback scheduler (set true if you are NOT using n8n; runs node-cron inside the server) ---
ENABLE_INTERNAL_CRON=false
