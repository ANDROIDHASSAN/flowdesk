{
  "name": "Pulse CRM — 1. Follow-up due reminder (9:00 IST)",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [{ "field": "cronExpression", "expression": "0 9 * * *" }]
        }
      },
      "name": "Every morning 9:00 IST",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [240, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.PULSE_API_URL }}/api/automation/run/followup-due",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "x-service-token", "value": "={{ $env.PULSE_SERVICE_TOKEN }}" }
          ]
        },
        "options": {}
      },
      "name": "Run follow-up due job",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [480, 300]
    }
  ],
  "connections": {
    "Every morning 9:00 IST": {
      "main": [[{ "node": "Run follow-up due job", "type": "main", "index": 0 }]]
    }
  },
  "settings": { "timezone": "Asia/Kolkata" },
  "active": false
}
