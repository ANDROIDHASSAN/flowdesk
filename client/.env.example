# ─── Production API URL (Render backend) ─────────────────────────────────────
# Set this in Vercel dashboard → Project Settings → Environment Variables
# Format: https://<your-render-service>.onrender.com/api  (include /api)
# In local dev, leave this UNSET — Vite proxy forwards /api → http://localhost:4000
VITE_API_URL=https://flowdesk-api.onrender.com/api
